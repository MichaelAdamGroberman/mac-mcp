  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MichaelAdamGroberman/mac-mcp"
  },
  "license": "MIT",
  "homepage": "https://github.com/MichaelAdamGroberman/mac-mcp",
  "documentation": "https://github.com/MichaelAdamGroberman/mac-mcp#readme",
  "support": "https://github.com/MichaelAdamGroberman/mac-mcp/issues",
  "keywords": [
    "macos", "automation", "accessibility", "applescript", "osakit",
    "mcp", "claude-desktop", "mcpb", "dxt", "iphone-mirroring",
    "iterm", "terminal", "swift"
  ],
  "platforms": ["darwin"],
