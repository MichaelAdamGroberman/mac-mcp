{
  "$schema": "https://claude.ai/schemas/plugin-marketplace.json",
  "name": "mac-mcp",
  "display_name": "macOS Native Control (MCP)",
  "version": "0.1.0",
  "description": "Native macOS control: 32 typed allow-listed tools across windows, Finder, clipboard, screenshots, mouse/keyboard, app automation (Mail/Calendar/Messages/Safari/Notes), iTerm/Terminal, and iPhone Mirroring. Code-signed for stable TCC grants. No raw shell or AppleScript exec.",
